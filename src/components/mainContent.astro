---
---
<section class="hero-section">
  <div class="container">
    <h2>Simulador de Préstamos</h2>
    <p class="subtitle">
      Completa el formulario para obtener una cotización instantánea de tu préstamo personal. Fácil, rápido y transparente.
    </p>

    <form id="loan-form">
      <label for="amount">Monto:</label>
      <div class="amount-tags"></div>
      <input type="number" id="amount" placeholder="Ej: 10000" required />

      <label for="currency">Moneda:</label>
      <select id="currency">
        <option value="ARS">Pesos Argentinos (ARS)</option>
        <option value="USD">Dólares (USD)</option>
      </select>

      <label for="installments">Cuotas:</label>
      <select id="installments">
        <option value="1">1 cuota</option>
        <option value="2">2 cuotas</option>
        <option value="3">3 cuotas</option>
        <option value="4">4 cuotas</option>
        <option value="5">5 cuotas</option>
      </select>

      <label for="payment-value">Valor a pagar por cuota:</label>
      <p id="payment-value" class="payment-display"></p>

      <div class="button-group">
        <button type="submit">Calcular</button>
        <a href="#" id="whatsapp-button" class="whatsapp-button" target="_blank">
            <i class="fa-brands fa-whatsapp"></i>
        <span>Solcitar Préstamo</span>
  </a>
      </div>
    </form>

    <div id="result"></div>
  </div>
</section>
<style>
    /* 4. Estilos del Formulario */
:global(.amount-tag) {
  background: #f1f3f5;
  border: 1px solid var(--border-color);
  margin-bottom: 1rem;
  border-radius: 999px;
  padding: 0.3rem 0.7rem;
  font-size: 0.75rem;
  cursor: pointer;
  color: #333;
  transition: all 0.2s ease;
}

:global(.amount-tag:hover) {
  background: var(--accent-color);
  color: white;
}

:global(.amount-tag.active) {
  background: var(--accent-color);
  color: white;
}
.hero-section {
    background-color: var(--secondary-color);
    padding: 4rem 1rem;
}
form {
  background: white;
  padding: 1.2rem;
  border-radius: var(--border-radius);
  margin-top: 1rem;
  border: 1px solid var(--border-color);
  box-shadow: 0 4px 6px rgba(0,0,0,0.05);
}

label {
  display: block;
  margin-bottom: 0.3rem;
  font-weight: 700;
  font-size: 0.8rem;
}

input, select, .payment-display {
  width: 100%;
  padding: 0.6rem;
  margin-bottom: 0.8rem;
  border: 1px solid var(--border-color);
  border-radius: var(--border-radius);
  font-size: 0.9rem;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

input:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
    box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.2);
}

/* Estilos para el nuevo contenedor de botones */
.button-group {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.8rem;
}

/* Estilos generales para ambos botones */
.button-group button, .button-group .whatsapp-button {
  flex: 1;
  padding: 0.6rem;
  border: none;
  border-radius: var(--border-radius);
  cursor: pointer;
  font-size: 0.85rem;
  font-weight: 700;
  text-decoration: none;
  text-align: center;
  transition: background-color 0.2s ease;
}

/* Estilos específicos para cada botón */
button {
  background: var(--accent-color);
  color: white;
}

button:hover {
  background: #0056b3;
}

.whatsapp-button {
  background-color: #25d366;
  color: white;
  /* Usamos Flexbox para alinear el ícono y el texto */
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.5rem;
}

.whatsapp-button:hover {
  background-color: #128c7e;
}

/* 5. Estilos para los Resultados */
#result {
  margin-top: 2rem;
  background: white;
  padding: 1.5rem;
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

#result.visible {
    opacity: 1;
    transform: translateY(0);
}
</style>
<script>
document.addEventListener('DOMContentLoaded', () => {

  const form = document.getElementById('loan-form');
  const amountInput = document.getElementById('amount');
  const installmentsInput = document.getElementById('installments');
  const paymentValueParagraph = document.getElementById('payment-value');
  const resultDiv = document.getElementById('result');
  const whatsappButton = document.getElementById('whatsapp-button');
  const currencySelect = document.getElementById('currency');
  const tagsContainer = document.querySelector('.amount-tags');

  if (!form || !amountInput || !installmentsInput || !paymentValueParagraph || !whatsappButton || !currencySelect || !tagsContainer) {
    console.error('Faltan elementos del DOM');
    return;
  }

  type Currency = 'ARS' | 'USD';

  const amountsByCurrency: Record<Currency, number[]> = {
    ARS: [5000, 10000, 20000, 50000, 100000],
    USD: [10, 20, 50, 100, 200]
  };

  // 🔥 Tipamos parámetro
  function renderTags(currency: Currency) {
    tagsContainer.innerHTML = '';

    amountsByCurrency[currency].forEach((amount: number) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'amount-tag';

      btn.textContent = currency === 'ARS'
        ? `$${amount.toLocaleString('es-AR')}`
        : `USD ${amount.toLocaleString('en-US')}`;

      btn.addEventListener('click', () => {
        amountInput.value = amount.toString();

        document.querySelectorAll('.amount-tag')
          .forEach(t => t.classList.remove('active'));

        btn.classList.add('active');
      });

      tagsContainer.appendChild(btn);
    });
  }

  // 🔥 Init
  renderTags(currencySelect.value as Currency);

  currencySelect.addEventListener('change', () => {
    renderTags(currencySelect.value as Currency);
    amountInput.value = '';
  });

  // submit
  form.addEventListener('submit', (e) => {
    e.preventDefault();

    const monto = parseFloat(amountInput.value);
    const moneda = currencySelect.value;
    const cuotas = parseInt(installmentsInput.value);

    let totalInteres = 0;

    switch (cuotas) {
      case 1: totalInteres = monto * 0.25; break;
      case 2: totalInteres = monto * 0.50; break;
      case 3: totalInteres = monto * 0.75; break;
      case 4: totalInteres = monto * 1; break;
      case 5: totalInteres = monto * 1.25; break;
    }

    const totalPagar = monto + totalInteres;
    const pagoMensual = totalPagar / cuotas;

    paymentValueParagraph.textContent = `${moneda} ${pagoMensual.toFixed(2)}`;

    const message = `Hola, me gustaría solicitar un préstamo de ${moneda} ${monto} en ${cuotas} cuotas.`;
    const whatsappUrl = `https://wa.me/5493517516089?text=${encodeURIComponent(message)}`;
    whatsappButton.href = whatsappUrl;

    resultDiv.innerHTML = `
      <h3>Resumen de tu préstamo:</h3>
      <p><strong>Monto:</strong> ${moneda} ${monto.toFixed(2)}</p>
      <p><strong>Pago mensual:</strong> ${moneda} ${pagoMensual.toFixed(2)}</p>
    `;

    resultDiv.classList.add('visible');
  });

});
</script>
